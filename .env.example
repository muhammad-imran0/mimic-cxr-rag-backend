# Qdrant (same collection as the ingestion pipeline)
QDRANT_URL=https://your-cluster-url.qdrant.tech
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=mimic_cxr_vectors

# Path to MIMIC parquet files (from ingestion pipeline)
MIMIC_DATA_DIR=../biomedclip-embedding-pipeline/data/mimic-cxr/data

# Server
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,https://muhammad-imran0.github.io
